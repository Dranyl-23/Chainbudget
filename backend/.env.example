# Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git

# ── MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@chainbudget.xxxxx.mongodb.net/chainbudget?retryWrites=true&w=majority

# ── JWT secret key (generate a long random string)
JWT_SECRET=replace_with_a_long_random_secret_string_here

# ── Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ── Port (Railway will inject this automatically)
PORT=5000

# ── Smart contract address (set after deploying ChainBudget.sol)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── Backend service wallet (used to call smart contract from the server)
# This is a DIFFERENT key from your personal MetaMask wallet
# Generate a dedicated deployer/service wallet and fund it with test MATIC
BACKEND_WALLET_PRIVATE_KEY=your_backend_service_wallet_private_key_here

# ── Polygon Amoy RPC URL
AMOY_RPC_URL=https://rpc-amoy.polygon.technology/

# ── Asgardeo (to be configured when Asgardeo is set up)
ASGARDEO_BASE_URL=https://api.asgardeo.io/t/<>
ASGARDEO_CLIENT_ID=
ASGARDEO_CLIENT_SECRET=

SMTP_EMAIL=imong_tinuod_nga_email@gmail.com
SMTP_PASSWORD=imong_app_password